# Copy to .bws.env on the VM and fill in. .bws.env is gitignored — never commit it.
# Bitwarden Secrets Manager machine-account access token (Secrets Manager >
# Machine accounts > Access tokens). Grants read access to the project's secrets.
BWS_ACCESS_TOKEN=0.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# UUID of the secret holding the Grafana admin password (bws secret list | jq).
GF_ADMIN_SECRET_ID=00000000-0000-0000-0000-000000000000
